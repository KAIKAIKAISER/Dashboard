{
  "name": "Howdz起始页",
  "version": "1.9.0",
  "description": "提供大量组件用于定制化你的起始页，可适配响应式设计。",
  "icons": {
    "128": "favicon.png"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://aviationweather.gov/*"
  ],
  "background": {
    "service_worker": "sw.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "favicon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src 'self' https://aviationweather.gov; object-src 'self'"
  },
  "offline_enabled": true,
  "manifest_version": 3,
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
